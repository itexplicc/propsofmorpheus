nt:space-between;align-items:center;gap:14px;margin-top:20px}.status{min-height:22px;color:var(--muted);font-size:12px}.ok{color:#28724c;font-weight:800}.bad{color:#9d3e33;font-weight:800}.faq{display:grid;gap:10px}.faq article{border:1px solid var(--line);border-radius:18px;background:#ffffffa8;overflow:hidden}.faq button{width:100%;display:flex;justify-content:space-between;padding:19px 20px;border:0;background:none;color:var(--ink);font:20px var(--serif);text-align:left}.answer{max-height:0;overflow:hidden;transition:.25s}.answer p{margin:0;padding:0 20px 21px;color:#092d49a6;font-size:13px}.faq article.open .answer{max-height:320px}.cta{display:grid;grid-template-columns:1fr auto;gap:28px;align-items:center;padding:clamp(30px,5vw,58px);border-radius:32px;color:#fff;background:var(--deep);box-shadow:var(--shadow)}.cta h2{margin:0;font:clamp(32px,4vw,54px)/1.04 var(--serif)}.cta p{color:#ffffff9e}.footer{color:#ffffffa6;background:var(--deep)}.footerMain{padding:70px 0 48px;display:grid;grid-template-columns:1.2fr .8fr .8fr 1fr;gap:42px}.footer img{width:300px;filter:brightness(0) invert(1)}.footer p{color:#ffffff8f;font-size:12px}.footer strong{display:block;margin-bottom:14px;color:#fff;font-size:9px;letter-spacing:.13em;text-transform:uppercase}.footer a{display:block;margin:9px 0;color:#ffffff9a;text-decoration:none;font-size:12px}.newsletter{display:flex;gap:8px}.newsletter input{height:45px;color:#fff;border-color:#ffffff26;background:#ffffff12}.newsletter button{min-height:45px;color:var(--deep);background:#fff}.footerBottom{padding:18px 0;border-top:1px solid #ffffff17;display:flex;justify-content:space-between;font-size:9px}.reveal{opacity:0;transform:translateY(22px);transition:.7s}.reveal.visible{opacity:1;transform:none}@media(max-width:1000px){.desktop{display:none}.heroGrid,.grid2{grid-template-columns:1fr}.grid3,.products{grid-template-columns:1fr 1fr}.grid4{grid-template-columns:1fr 1fr}.footerMain{grid-template-columns:1fr 1fr}.brand img{width:275px}}@media(max-width:700px){.shell,.narrow{width:min(100% - 24px,1220px)}.section{padding:74px 0}.utility .shell{justify-content:center}.utility span:last-child{display:none}.nav{min-height:70px}.brand img{width:220px}.review{display:none}.hero{min-height:520px;padding:72px 0}.display{font-size:clamp(43px,14vw,66px)}.pack img{border-radius:25px 25px 25px 64px}.badge{left:-2px;bottom:12px;width:104px;border-width:5px;font-size:12px}.strip .shell,.grid3,.grid4,.products,.species,.formgrid{grid-template-columns:1fr}.strip article{border-right:0;border-bottom:1px solid #ffffff1c}.timeline div{grid-template-columns:1fr;gap:8px}.transition{grid-template-columns:1fr}.formactions,.cta{grid-template-columns:1fr;align-items:stretch}.footerMain{grid-template-columns:1fr}.footerBottom{flex-direction:column;gap:10px}.newsletter{flex-direction:column}}
'''
(OUT / "assets/css/site.css").write_text(CSS)

JS = r'''
const q=(s,c=document)=>c.querySelector(s),qa=(s,c=document)=>[...c.querySelectorAll(s)];const P=[['Home','index.html','MAKO premium dog and cat food'],['Products','products.html','Dog and cat product range'],['Daily Diet','daily-diet.html','Fish-first hero product'],['Ingredients','ingredients.html','Sea and soil ingredients'],['Nutrition','nutrition.html','Species-aware nutrition'],['Feeding Guide','feeding-guide.html','Dog and cat feeding support'],['Our Story','our-story.html','MAKO brand purpose'],['Responsibility','sustainability.html','Responsible sourcing'],['Retail & Trade','trade.html','Retail and distribution'],['FAQ','faq.html','Common questions'],['Contact','contact.html','Contact MAKO'],['Private Review','review.html','George brand review']];
function start(){const d=q('#drawer'),m=q('#menu'),x=q('#close');m?.addEventListener('click',()=>{d.classList.add('open');document.body.classList.add('lock')});x?.addEventListener('click',()=>{d.classList.remove('open');document.body.classList.remove('lock')});const sm=q('#search'),so=q('#searchOpen'),sc=q('#searchClose'),si=q('#searchInput'),sr=q('#searchResults');const render=t=>{t=t.toLowerCase();sr.innerHTML=P.filter(a=>!t||(a.join(' ').toLowerCase().includes(t))).map(a=>`<a class="result" href="${a[1]}"><b>${a[0]}</b><span>${a[2]}</span></a>`).join('')};so?.addEventListener('click',()=>{sm.classList.add('open');render('');setTimeout(()=>si.focus(),50)});sc?.addEventListener('click',()=>sm.classList.remove('open'));si?.addEventListener('input',()=>render(si.value));const ob=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');ob.unobserve(e.target)}}),{threshold:.1});qa('.reveal').forEach(e=>ob.observe(e));addEventListener('scroll',()=>{const n=document.documentElement.scrollHeight-innerHeight;q('#progress').style.width=(n?scrollY/n*100:0)+'%'},{passive:true});qa('.faq button').forEach(b=>b.onclick=()=>b.parentElement.classList.toggle('open'));qa('.tab').forEach(b=>b.onclick=()=>{const g=b.closest('[data-tabs]');qa('.tab',g).forEach(x=>x.classList.remove('active'));qa('.panel',g).forEach(x=>x.classList.remove('active'));b.classList.add('active');q('#'+b.dataset.tab,g).classList.add('active')});forms();planner()}
const U='https://zadxvmpgngwtpsmdkcod.supabase.co',K='sb_publishable_MxL_uLP-7iWrPDIM2J_RPQ_cDiVHZoA';async function post(t,p){const r=await fetch(`${U}/rest/v1/${t}`,{method:'POST',headers:{apikey:K,Authorization:'Bearer '+K,'Content-Type':'application/json',Prefer:'return=minimal'},body:JSON.stringify(p)});if(!r.ok)throw Error(await r.text())}
function forms(){qa('.inquiry').forEach(f=>f.onsubmit=async e=>{e.preventDefault();if(!f.reportValidity())return;const d=new FormData(f),s=q('.status',f),b=q('button[type=submit]',f),old=b.textContent;b.disabled=true;b.textContent='Sending…';try{await post('mako_inquiries',{inquiry_type:d.get('inquiry_type')||'general',full_name:d.get('full_name'),email:d.get('email'),phone:d.get('phone')||null,company_name:d.get('company_name')||null,country:d.get('country')||null,subject:d.get('su