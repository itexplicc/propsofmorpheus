px;transform:translateX(102%);transition:.32s;color:#fff;background:var(--deep);overflow:auto}.drawer.open{transform:none}.drawer button{position:absolute;right:22px;top:22px;width:44px;height:44px;border:1px solid #ffffff2b;border-radius:50%;color:#fff;background:none;font-size:22px}.drawer nav{display:grid}.drawer a{padding:15px 0;border-bottom:1px solid #ffffff1c;color:#fff;text-decoration:none;font:24px var(--serif)}.search{position:fixed;inset:0;z-index:2600;display:none;padding:9vh 18px;background:#03121fee;backdrop-filter:blur(13px)}.search.open{display:block}.searchbox{width:min(760px,100%);margin:auto;padding:28px;border-radius:25px;background:var(--paper);box-shadow:var(--shadow)}.searchhead{display:flex;justify-content:space-between;align-items:center}.searchhead h2{margin:0;font:32px var(--serif)}.searchhead button{border:0;background:none;font-size:25px}.search input{width:100%;height:58px;margin:20px 0 12px;padding:0 17px;border:1px solid var(--line);border-radius:15px}.results{display:grid;gap:8px}.result{padding:14px;border:1px solid var(--line);border-radius:14px;text-decoration:none}.result span{display:block;color:var(--muted);font-size:12px}.hero{min-height:620px;display:grid;align-items:center;padding:88px 0;background:radial-gradient(circle at 12% 10%,#fff,transparent 28%),radial-gradient(circle at 90% 18%,#4f81842e,transparent 29%),linear-gradient(135deg,#fbf7ef,#ece0d0)}.hero.dark{color:#fff;background:radial-gradient(circle at 80% 20%,#4f81844a,transparent 30%),linear-gradient(135deg,#061d32,#0a3b59)}.hero.dark .lead{color:#ffffffb0}.heroGrid{display:grid;grid-template-columns:.85fr 1.15fr;gap:60px;align-items:center}.pack{position:relative}.pack img{width:100%;border-radius:38px 38px 38px 105px;box-shadow:var(--shadow);border:1px solid var(--line)}.badge{position:absolute;left:-18px;bottom:28px;width:138px;aspect-ratio:1;display:grid;place-items:center;padding:20px;border:6px solid #fffdf8e8;border-radius:50%;color:#fff;background:var(--deep);text-align:center;font:16px/1.08 var(--serif);text-transform:uppercase;transform:rotate(-7deg)}.proof{display:flex;flex-wrap:wrap;gap:13px 22px;margin-top:30px;color:#092d499e;font-size:9px;font-weight:900;letter-spacing:.11em;text-transform:uppercase}.proof span:before{content:"";display:inline-block;width:7px;height:7px;margin-right:8px;border-radius:50%;background:var(--coral);box-shadow:0 0 0 5px #c971561a}.strip{color:#fff;background:var(--deep)}.strip .shell{display:grid;grid-template-columns:repeat(4,1fr)}.strip article{min-height:145px;padding:28px 24px;display:flex;flex-direction:column;justify-content:center;border-right:1px solid #ffffff1c}.strip article:last-child{border:0}.strip strong{font:20px var(--serif)}.strip span{margin-top:5px;color:#ffffff94;font-size:12px}.image{overflow:hidden;border:1px solid var(--line);border-radius:30px;background:#fff;box-shadow:var(--shadow)}.image img{width:100%;height:100%;object-fit:cover}.darkSection{color:#fff;background:radial-gradient(circle at 12% 8%,#4f818445,transparent 32%),linear-gradient(135deg,#061d32,#0a3b59)}.darkSection .lead,.darkSection .muted{color:#ffffffa6}.card{min-height:250px;padding:27px;border:1px solid var(--line);border-radius:24px;background:#ffffffad;box-shadow:0 18px 50px #041a2d17}.darkSection .card{border-color:#ffffff21;background:#ffffff0e}.card h3{margin:42px 0 8px;font:26px var(--serif)}.card p{color:#092d49a3;font-size:13px}.darkSection .card p{color:#ffffff9e}.number{font:56px/1 var(--serif);color:#092d4929}.darkSection .number{color:#ffffff2e}.species{display:grid;grid-template-columns:1fr 1fr;gap:18px}.species article{min-height:390px;padding:34px;border:1px solid var(--line);border-radius:30px;background:#ffffffad;box-shadow:0 18px 50px #041a2d17}.species i{width:76px;height:76px;display:grid;place-items:center;border-radius:50%;color:#fff;background:var(--ink);font:30px var(--serif)}.species h3{margin:90px 0 10px;font:38px var(--serif)}.products{display:grid;grid-template-columns:repeat(3,1fr);gap:17px}.product{position:relative;min-height:465px;padding:24px;border:1px solid var(--line);border-radius:29px;background:#ffffffad;box-shadow:0 18px 50px #041a2d17}.product.featured{color:#fff;background:var(--ink)}.product img{height:230px;margin:auto;border-radius:14px;box-shadow:0 17px 35px #041a2d24}.product h3{margin:20px 0 7px;font:29px var(--serif)}.product p{color:#092d499e;font-size:13px}.product.featured p{color:#ffffff9e}.tag{display:inline-flex;padding:7px 10px;border-radius:999px;background:var(--mist);font-size:8px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}.featured .tag{color:var(--ink);background:#fff}.timeline{display:grid}.timeline div{display:grid;grid-template-columns:125px 1fr;gap:26px;padding:23px 0;border-bottom:1px solid var(--line)}.timeline strong{font:26px var(--serif)}.timeline p{margin:0;color:#092d49a6}.tabs{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:25px}.tab{padding:11px 14px;border:1px solid var(--line);border-radius:999px;background:#ffffffa0;cursor:pointer;font-size:9px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.tab.active{color:#fff;background:var(--ink)}.panel{display:none}.panel.active{display:block}.transition{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.transition div{padding:20px;border:1px solid var(--line);border-radius:20px;background:#ffffffa8}.transition strong{display:block;font:22px var(--serif)}.form{padding:30px;border:1px solid var(--line);border-radius:27px;background:#ffffffb2;box-shadow:0 18px 50px #041a2d17}.formgrid{display:grid;grid-template-columns:1fr 1fr;gap:16px}.field{display:grid;gap:8px}.full{grid-column:1/-1}.field label,.label{font-size:9px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}input,select,textarea{width:100%;border:1px solid #092d4929;border-radius:14px;background:#fffdf9}input,select{height:50px;padding:0 14px}textarea{min-height:125px;padding:13px 14px}.formactions{display:flex;justify-conte